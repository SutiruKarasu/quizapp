<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tatiana Lumos | Maintenance</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&family=Lato:wght@300;400&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Italianno&display=swap" rel="stylesheet">
    <style>
        /* ── CSS Variables matching main site ─────────────────────────── */
        :root {
            --powder-blue: #00aaff;
            --baby-pink: #00aaff;
            --bg-main: #ffffff;
            --text-dark: #1a1a1a;
            --text-muted: #4a4a4a;
            --navbar-bg: rgba(255, 255, 255, 0.92);
            --input-bg: rgba(255, 255, 255, 0.5);
            --input-border: #dcdcdc;
        }

        body.dark-mode {
            --bg-main: #121418;
            --text-dark: #f5f5f5;
            --text-muted: #b5c0cd;
            --navbar-bg: rgba(18, 20, 24, 0.92);
            --input-bg: rgba(255, 255, 255, 0.03);
            --input-border: #3a414c;
        }

        html, * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Lato', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-dark);
            height: 100dvh;
            overflow: hidden;
            transition: background-color 0.5s ease, color 0.5s ease;
        }

        @media (min-width: 768px) {
            body { cursor: none; }
            a, button, input { cursor: none !important; }
        }

        /* ── Bokeh canvas ─────────────────────────────────────────────── */
        #bokeh-canvas {
            position: fixed;
            inset: 0;
            width: 100%; height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* ── Background gradient overlay ─────────────────────────────── */
        .bg-overlay {
            position: fixed;
            inset: 0;
            background: linear-gradient(135deg, rgba(255, 51, 136, 0.07) 0%, rgba(0, 170, 255, 0.07) 100%);
            z-index: 1;
            pointer-events: none;
            transition: background 0.5s ease;
        }

        body.dark-mode .bg-overlay {
            background: linear-gradient(135deg, #181c24 0%, #221a20 100%);
        }

        /* ── Camera flash ─────────────────────────────────────────────── */
        #camera-flash {
            position: fixed;
            inset: 0;
            background-color: white;
            z-index: 99999;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.5s ease-out;
        }
        #camera-flash.flash-active {
            opacity: 1;
            transition: opacity 0.05s ease-in;
        }

        /* ── Custom cursor ────────────────────────────────────────────── */
        .custom-cursor {
            width: 20px; height: 20px;
            border: 1px solid var(--baby-pink);
            border-radius: 50%;
            position: fixed;
            transform: translate(-50%, -50%);
            pointer-events: none;
            z-index: 9999;
            transition: transform 0.1s ease, background-color 0.3s ease, border-color 0.3s ease;
        }
        .custom-cursor.hover {
            transform: translate(-50%, -50%) scale(2.5);
            background-color: rgba(176, 224, 230, 0.3);
            border-color: var(--powder-blue);
        }

        /* ── Theme toggle ─────────────────────────────────────────────── */
        .theme-btn {
            position: fixed;
            top: 30px; right: 30px;
            background: none;
            border: none;
            font-size: 1.2rem;
            outline: none;
            z-index: 500;
            transition: transform 0.3s ease;
            cursor: none;
        }
        .theme-btn:hover { transform: scale(1.2) rotate(12deg); }

        /* ── Main container ───────────────────────────────────────────── */
        .maintenance-container {
            position: relative;
            z-index: 10;
            height: 100dvh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 2rem;
            gap: 0;
        }

        /* ── Logo ─────────────────────────────────────────────────────── */
        .logo-wordmark {
            font-family: 'Italianno', cursive;
            font-size: 3rem;
            color: var(--text-dark);
            letter-spacing: 4px;
            margin-bottom: 2.8rem;
            opacity: 0;
            animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 0.3s forwards;
            transition: color 0.5s;
        }

        /* ── Main title ───────────────────────────────────────────────── */
        .maintenance-title {
            font-family: 'Playfair Display', serif;
            font-weight: 400;
            font-size: clamp(1.8rem, 4.5vw, 3.8rem);
            letter-spacing: 7px;
            text-transform: uppercase;
            line-height: 1.25;
            margin-bottom: 0;
            opacity: 0;
            /* Shimmer is applied after fade-up via JS adding class */
            animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 0.6s forwards;
            position: relative;
            /* Shimmer background */
            background: linear-gradient(
                105deg,
                var(--text-dark) 0%,
                var(--text-dark) 38%,
                rgba(176, 224, 230, 0.95) 50%,
                var(--text-dark) 62%,
                var(--text-dark) 100%
            );
            background-size: 250% auto;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .maintenance-title.shimmer-active {
            animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 0.6s forwards,
                       shimmer 5s linear 1.8s infinite;
        }

        @keyframes shimmer {
            0%   { background-position: 250% center; }
            100% { background-position: -250% center; }
        }

        /* ── Decorative line ──────────────────────────────────────────── */
        .deco-line {
            width: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--baby-pink), transparent);
            margin: 1.8rem auto;
            animation: expandLine 1.2s cubic-bezier(0.25, 1, 0.5, 1) 1.3s forwards;
        }

        @keyframes expandLine {
            from { width: 0; opacity: 0; }
            to   { width: 160px; opacity: 1; }
        }

        /* ── Subtitle ─────────────────────────────────────────────────── */
        .maintenance-subtitle {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: clamp(0.9rem, 2vw, 1.25rem);
            color: var(--text-muted);
            letter-spacing: 1.5px;
            margin-bottom: 2.8rem;
            line-height: 1.7;
            opacity: 0;
            animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 1s forwards;
            transition: color 0.5s;
        }

        /* ── Notify form ──────────────────────────────────────────────── */
        .notify-wrapper {
            opacity: 0;
            animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 1.4s forwards;
            width: 100%;
            max-width: 420px;
        }

        .notify-form {
            display: flex;
        }

        .notify-input {
            flex: 1;
            padding: 14px 18px;
            border: 1px solid var(--input-border);
            border-right: none;
            background: var(--input-bg);
            color: var(--text-dark);
            font-family: 'Lato', sans-serif;
            font-size: 0.84rem;
            letter-spacing: 1px;
            outline: none;
            transition: border-color 0.3s, background 0.5s;
            backdrop-filter: blur(6px);
        }
        .notify-input::placeholder { color: var(--text-muted); opacity: 0.75; }
        .notify-input:focus { border-color: var(--powder-blue); }

        .notify-btn {
            padding: 14px 22px;
            background: var(--baby-pink);
            color: #fff;
            border: 1px solid var(--baby-pink);
            font-family: 'Lato', sans-serif;
            font-size: 0.78rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            white-space: nowrap;
            transition: background 0.3s, transform 0.2s, border-color 0.3s;
        }
        .notify-btn:hover {
            background: transparent;
            color: var(--text-dark);
            border-color: var(--input-border);
        }

        .notify-success {
            display: none;
            font-family: 'Playfair Display', serif;
            font-style: italic;
            color: var(--text-muted);
            font-size: 1rem;
            letter-spacing: 1px;
            padding: 14px 0;
            animation: fadeUp 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            transition: color 0.5s;
        }

        /* ── Social link ──────────────────────────────────────────────── */
        .social-row {
            margin-top: 2.5rem;
            opacity: 0;
            animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 1.8s forwards;
        }

        .ig-link {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 3.5px;
            border-bottom: 1px solid transparent;
            padding-bottom: 2px;
            transition: color 0.3s, border-color 0.3s;
        }
        .ig-link:hover {
            color: var(--powder-blue);
            border-bottom-color: var(--powder-blue);
        }

        /* ── Bottom hint ──────────────────────────────────────────────── */
        .click-hint {
            position: fixed;
            bottom: 28px;
            left: 50%;
            transform: translateX(-50%);
            font-family: 'Lato', sans-serif;
            font-size: 0.68rem;
            letter-spacing: 3.5px;
            text-transform: uppercase;
            color: var(--text-muted);
            opacity: 0;
            animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 2.4s forwards;
            pointer-events: none;
            white-space: nowrap;
            transition: color 0.5s;
        }

        /* ── Click counter ────────────────────────────────────────────── */
        #click-counter {
            position: fixed;
            bottom: 28px;
            right: 30px;
            font-family: 'Playfair Display', serif;
            font-size: 0.72rem;
            color: var(--text-muted);
            opacity: 0;
            transition: opacity 0.5s, color 0.5s;
            pointer-events: none;
            letter-spacing: 2px;
        }
        #click-counter.visible { opacity: 0.45; }

        /* ── Easter egg modal ─────────────────────────────────────────── */
        #easter-egg {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.85);
            background: var(--navbar-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--input-border);
            padding: 2.8rem 4.5rem;
            text-align: center;
            z-index: 5000;
            pointer-events: none;
            transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.5s;
            opacity: 0;
        }
        #easter-egg.active {
            transform: translate(-50%, -50%) scale(1);
            opacity: 1;
            pointer-events: auto;
        }
        #easter-egg .egg-title {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: 1.4rem;
            color: var(--text-dark);
            letter-spacing: 1px;
            margin-bottom: 0.8rem;
            transition: color 0.5s;
        }
        #easter-egg .egg-sub {
            font-family: 'Lato', sans-serif;
            font-size: 0.72rem;
            letter-spacing: 3.5px;
            text-transform: uppercase;
            color: var(--text-muted);
            transition: color 0.5s;
        }
        #easter-egg .egg-line {
            width: 40px;
            height: 1px;
            background: var(--baby-pink);
            margin: 1.2rem auto;
        }

        /* ── Floating background letters ──────────────────────────────── */
        .lumos-letter {
            position: fixed;
            font-family: 'Playfair Display', serif;
            color: var(--text-muted);
            opacity: 0;
            pointer-events: none;
            z-index: 2;
            text-transform: uppercase;
            animation: floatLetter linear infinite;
            transition: color 0.5s;
        }

        @keyframes floatLetter {
            0%   { transform: translateY(108vh) rotate(0deg);   opacity: 0; }
            8%   { opacity: 0.07; }
            90%  { opacity: 0.07; }
            100% { transform: translateY(-8vh)  rotate(360deg); opacity: 0; }
        }

        /* ── Ripple on click ──────────────────────────────────────────── */
        .ripple {
            position: fixed;
            border-radius: 50%;
            border: 1px solid var(--baby-pink);
            transform: translate(-50%, -50%) scale(0);
            pointer-events: none;
            z-index: 8000;
            animation: rippleOut 0.7s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        @keyframes rippleOut {
            from { transform: translate(-50%, -50%) scale(0); opacity: 0.6; }
            to   { transform: translate(-50%, -50%) scale(6); opacity: 0; }
        }

        /* ── Entrance ─────────────────────────────────────────────────── */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(22px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Mobile ───────────────────────────────────────────────────── */
        @media (max-width: 600px) {
            .maintenance-title { letter-spacing: 3px; }
            .logo-wordmark { font-size: 2.4rem; }
            .notify-form { flex-direction: column; }
            .notify-input { border-right: 1px solid var(--input-border); border-bottom: none; }
            .theme-btn { top: 20px; right: 20px; }
            #easter-egg { padding: 2.2rem 2.5rem; }
            .click-hint { display: none; }
        }
    </style>
</head>
<body>

    <div id="camera-flash"></div>
    <div class="custom-cursor" id="cursor"></div>
    <canvas id="bokeh-canvas"></canvas>
    <div class="bg-overlay"></div>

    <button class="theme-btn" id="theme-toggle" aria-label="Toggle Theme">🌙</button>

    <main class="maintenance-container" role="main">

        <div class="logo-wordmark">Tatiana Lumos</div>

        <h1 class="maintenance-title" id="mainTitle">
            Currently Under<br>Maintenance
        </h1>

        <div class="deco-line"></div>

        <p class="maintenance-subtitle">
            We are perfecting the experience.<br>Back very soon.
        </p>

        <div class="notify-wrapper">
            <form class="notify-form" id="notifyForm" novalidate>
                <input
                    type="email"
                    class="notify-input"
                    id="emailInput"
                    placeholder="Your email address"
                    autocomplete="email"
                    aria-label="Email address for notification"
                    required
                >
                <button type="submit" class="notify-btn" aria-label="Notify me when back">Notify Me</button>
            </form>
            <p class="notify-success" id="notifySuccess" aria-live="polite">
                You will be the first to know &mdash; thank you.
            </p>
        </div>

        <div class="social-row">
            <a
                href="https://instagram.com/tatiana_lumos"
                target="_blank"
                rel="noopener noreferrer"
                class="ig-link"
                aria-label="Tatiana Lumos on Instagram"
            >Instagram</a>
        </div>

    </main>

    <p class="click-hint" aria-hidden="true">Click anywhere &mdash; go on</p>

    <div id="easter-egg" role="dialog" aria-label="Secret found" aria-hidden="true">
        <p class="egg-title">You found the secret frame</p>
        <div class="egg-line"></div>
        <p class="egg-sub">&#10022; &nbsp; Frame No. X &nbsp; &#10022;</p>
    </div>

    <div id="click-counter" aria-hidden="true"></div>

    <script>
    'use strict';

    // ── Theme ────────────────────────────────────────────────────────────────
    const themeBtn = document.getElementById('theme-toggle');
    const applyTheme = (dark) => {
        document.body.classList.toggle('dark-mode', dark);
        themeBtn.textContent = dark ? '☀️' : '🌙';
    };
    applyTheme(localStorage.getItem('theme') === 'dark');
    themeBtn.addEventListener('click', () => {
        const dark = !document.body.classList.contains('dark-mode');
        applyTheme(dark);
        localStorage.setItem('theme', dark ? 'dark' : 'light');
    });

    // ── Custom cursor ────────────────────────────────────────────────────────
    const cursor = document.getElementById('cursor');
    let mouseX = -200, mouseY = -200;

    document.addEventListener('mousemove', e => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        cursor.style.left = mouseX + 'px';
        cursor.style.top  = mouseY + 'px';
    });

    document.querySelectorAll('a, button, input').forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
    });

    // ── Camera flash ─────────────────────────────────────────────────────────
    const flashEl = document.getElementById('camera-flash');
    function triggerFlash() {
        flashEl.classList.add('flash-active');
        setTimeout(() => flashEl.classList.remove('flash-active'), 80);
    }

    // ── Ripple effect ─────────────────────────────────────────────────────────
    function spawnRipple(x, y) {
        const r = document.createElement('div');
        r.classList.add('ripple');
        r.style.left   = x + 'px';
        r.style.top    = y + 'px';
        r.style.width  = '60px';
        r.style.height = '60px';
        document.body.appendChild(r);
        setTimeout(() => r.remove(), 750);
    }

    // ── Bokeh canvas ──────────────────────────────────────────────────────────
    const canvas = document.getElementById('bokeh-canvas');
    const ctx    = canvas.getContext('2d');
    let W = 0, H = 0;

    function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    class Bokeh {
        constructor(x, y, burst) {
            this.burst  = !!burst;
            this.x      = x != null ? x : Math.random() * W;
            this.y      = y != null ? y : Math.random() * H;
            this.r      = this.burst
                            ? Math.random() * 9 + 3
                            : Math.random() * 40 + 8;
            const speed = this.burst ? 5 : 0.3;
            const angle = this.burst
                            ? Math.random() * Math.PI * 2
                            : Math.PI * 1.5 + (Math.random() - 0.5) * 0.4;
            const mag   = this.burst
                            ? Math.random() * speed + 0.5
                            : Math.random() * 0.35 + 0.08;
            this.vx     = Math.cos(angle) * mag;
            this.vy     = Math.sin(angle) * mag;
            this.baseOpacity = this.burst
                            ? Math.random() * 0.7 + 0.3
                            : Math.random() * 0.16 + 0.04;
            this.opacity     = this.baseOpacity;
            this.life        = 1;
            this.decay       = this.burst ? 0.013 + Math.random() * 0.018 : 0;
            // Alternate pink / blue palette matching brand
            const isPink = Math.random() < 0.48;
            this.cr = isPink ? 255 : 0;
            this.cg = isPink ? 80  : 160;
            this.cb = isPink ? 160 : 255;
        }

        update() {
            if (!this.burst) {
                const dx   = this.x - mouseX;
                const dy   = this.y - mouseY;
                const dist = Math.hypot(dx, dy);
                if (dist < 140) {
                    const f   = (140 - dist) / 140;
                    this.vx  += (dx / dist) * f * 0.22;
                    this.vy  += (dy / dist) * f * 0.22;
                }
                this.vx *= 0.97;
                this.vy *= 0.97;
                if (this.vy > -0.05) this.vy -= 0.01;
            } else {
                this.life    -= this.decay;
                this.opacity  = this.baseOpacity * Math.max(0, this.life);
                this.r       *= 0.975;
                this.vx      *= 0.96;
                this.vy      *= 0.96;
            }
            this.x += this.vx;
            this.y += this.vy;
            if (!this.burst) {
                if (this.y < -this.r) this.y = H + this.r;
                if (this.x < -this.r) this.x = W + this.r;
                if (this.x > W + this.r) this.x = -this.r;
            }
        }

        draw() {
            if (this.opacity <= 0.001) return;
            const g = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.r);
            g.addColorStop(0,   `rgba(${this.cr},${this.cg},${this.cb},${this.opacity})`);
            g.addColorStop(0.4, `rgba(${this.cr},${this.cg},${this.cb},${this.opacity * 0.4})`);
            g.addColorStop(1,   `rgba(${this.cr},${this.cg},${this.cb},0)`);
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
            ctx.fillStyle = g;
            ctx.fill();
        }

        isDead() { return this.burst && this.life <= 0; }
    }

    // Ambient particles
    const particles = [];
    for (let i = 0; i < 30; i++) particles.push(new Bokeh());

    (function loop() {
        ctx.clearRect(0, 0, W, H);
        for (let i = particles.length - 1; i >= 0; i--) {
            particles[i].update();
            particles[i].draw();
            if (particles[i].isDead()) particles.splice(i, 1);
        }
        requestAnimationFrame(loop);
    })();

    // ── Click interaction ─────────────────────────────────────────────────────
    let clickCount = 0;
    const counterEl  = document.getElementById('click-counter');
    const eggEl      = document.getElementById('easter-egg');
    const GOAL       = 10;

    document.addEventListener('click', e => {
        // Ignore form and theme btn
        if (e.target.closest('#notifyForm') || e.target.id === 'theme-toggle') return;

        triggerFlash();
        spawnRipple(e.clientX, e.clientY);

        // Burst bokeh at click
        const count = 16 + Math.floor(Math.random() * 8);
        for (let i = 0; i < count; i++) {
            particles.push(new Bokeh(e.clientX, e.clientY, true));
        }

        clickCount++;
        if (clickCount >= 2 && clickCount < GOAL) {
            counterEl.textContent = `${clickCount} / ${GOAL}`;
            counterEl.classList.add('visible');
        }
        if (clickCount === GOAL) showEasterEgg();
    });

    function showEasterEgg() {
        eggEl.setAttribute('aria-hidden', 'false');
        eggEl.classList.add('active');
        counterEl.textContent = '★';

        // Rain bokeh
        let rain = 0;
        const iv = setInterval(() => {
            particles.push(new Bokeh(Math.random() * W, Math.random() * H * 0.6, true));
            if (++rain >= 35) clearInterval(iv);
        }, 50);

        setTimeout(() => {
            eggEl.classList.remove('active');
            eggEl.setAttribute('aria-hidden', 'true');
            clickCount = 0;
            counterEl.classList.remove('visible');
        }, 3800);
    }

    // ── Floating LUMOS letters ────────────────────────────────────────────────
    const WORD = 'LUMOS';
    function spawnLetter() {
        const el = document.createElement('div');
        el.classList.add('lumos-letter');
        el.textContent    = WORD[Math.floor(Math.random() * WORD.length)];
        el.style.left     = (2 + Math.random() * 96) + 'vw';
        el.style.fontSize = (0.55 + Math.random() * 0.9) + 'rem';
        el.style.letterSpacing = (2 + Math.random() * 4) + 'px';
        const dur = 14 + Math.random() * 20;
        el.style.animationDuration = dur + 's';
        el.style.animationDelay    = (-Math.random() * dur * 0.5) + 's';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), dur * 1000 + 500);
    }
    for (let i = 0; i < 14; i++) spawnLetter();
    setInterval(spawnLetter, 3500);

    // ── Shimmer on title after entrance ──────────────────────────────────────
    const titleEl = document.getElementById('mainTitle');
    setTimeout(() => titleEl.classList.add('shimmer-active'), 1800);

    // ── Notify form ───────────────────────────────────────────────────────────
    const notifyForm    = document.getElementById('notifyForm');
    const notifySuccess = document.getElementById('notifySuccess');

    notifyForm.addEventListener('submit', e => {
        e.preventDefault();
